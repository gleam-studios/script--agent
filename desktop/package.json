{
  "name": "script-agent-desktop",
  "productName": "Script Agent",
  "version": "1.0.2",
  "description": "剧本 Agent 桌面版",
  "main": "main.cjs",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/gleam-studios/script--agent.git"
  },
  "scripts": {
    "prepare-resources": "node scripts/prepare-resources.mjs",
    "download-node": "node scripts/download-node.mjs",
    "stage": "npm run prepare-resources && npm run download-node",
    "pack": "npm run stage && electron-builder --dir",
    "dist": "npm run stage && electron-builder && node scripts/patch-mac-artifacts.mjs",
    "start": "electron ."
  },
  "build": {
    "publish": null,
    "appId": "com.gleamstudios.scriptagent",
    "productName": "Script Agent",
    "files": ["main.cjs", "package.json"],
    "directories": {
      "output": "release"
    },
    "extraResources": [
      { "from": "resources/next", "to": "next" },
      { "from": "resources/app-root", "to": "app-root" },
      { "from": "resources/node-bin", "to": "node-bin" }
    ],
    "win": {
      "target": ["nsis", "portable"]
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.productivity",
      "identity": null,
      "hardenedRuntime": false
    },
    "dmg": {
      "sign": false,
      "backgroundColor": "#f0f0f0",
      "window": {
        "width": 680,
        "height": 480
      },
      "contents": [
        {
          "x": 130,
          "y": 260,
          "type": "file",
          "name": "Script Agent.app"
        },
        {
          "x": 410,
          "y": 260,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 110,
          "type": "file",
          "path": "dmg-assets/安装说明.txt",
          "name": "安装说明.txt"
        },
        {
          "x": 410,
          "y": 110,
          "type": "file",
          "path": "dmg-assets/首次打开-解除隔离.command",
          "name": "首次打开-解除隔离.command"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8"
  }
}
